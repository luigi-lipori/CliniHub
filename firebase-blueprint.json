{
  "entities": {
    "Patient": {
      "title": "Patient",
      "description": "Patient data",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "cpf": { "type": "string" },
        "birthDate": { "type": "string", "format": "date" },
        "phone": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "cpf"]
    },
    "Doctor": {
      "title": "Doctor",
      "description": "Healthcare professional",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "crm": { "type": "string" },
        "specialty": { "type": "string" },
        "email": { "type": "string" }
      },
      "required": ["name", "crm", "specialty"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Scheduled medical consultation",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "doctorId": { "type": "string" },
        "roomId": { "type": "string" },
        "dateTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["scheduled", "completed", "cancelled"] }
      },
      "required": ["patientId", "doctorId", "roomId", "dateTime", "status"]
    }
  },
  "firestore": {
    "/patients": {
      "schema": "Patient",
      "description": "Collection of patients"
    },
    "/doctors": {
      "schema": "Doctor",
      "description": "Collection of doctors"
    },
    "/rooms": {
      "schema": { "$ref": "Room" },
      "description": "Available clinic rooms"
    },
    "/appointments": {
      "schema": "Appointment",
      "description": "Scheduled appointments"
    },
    "/ehr": {
      "schema": { "$ref": "EHRRecord" },
      "description": "Electronic Health Records"
    }
  }
}
